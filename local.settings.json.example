    "SENDER_EMAIL":          "it-automation-service@netradyne.com",
    "SENDER_PASSWORD":       "<app-password-or-leave-blank-to-use-keyvault>",

    "IT_EMAIL":              "it-operations@netradyne.com",
    "RECOVERY_GRACE_DAYS":   "30",

    "WEBHOOK_TOKEN":         "<optional-shared-secret-for-webhook-security>"
  }
}
